{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow view *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(head *)",
      "Bash(tail *)"
    ],
    "deny": [
      "Bash(npx *)",
      "Bash(pnpx *)",
      "Bash(pnpm dlx *)",
      "Bash(npm i)",
      "Bash(npm install)",
      "Bash(yarn add)",
      "Bash(pnpm i)",
      "Bash(pnpm install)",
      "Bash(pnpm add)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.ssh/**)",
      "Read(**/*token*)",
      "Read(**/.key/**)",
      "Read(**/key/**)",
      "Read(**/keys/**)",
      "Read(**/secrets/**)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git rebase *)"
    ]
  },
  "model": "opus",
  "autoMemoryEnabled": false,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "wezterm cli set-tab-title status:waiting",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "wezterm cli set-tab-title status:finish",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "jq -r --argjson now \"$(date +%s)\" '((.rate_limits.five_hour.resets_at // $now) - $now) as $s5 | ((.rate_limits.seven_day.resets_at // $now) - $now) as $s7 | \"[\\(.model.display_name)] ctx: \\(.context_window.used_percentage // 0)% | limits: \\(.rate_limits.five_hour.used_percentage // 0 | floor)%(\\($s5 / 3600 | floor)h\\($s5 % 3600 / 60 | floor)m)/\\(.rate_limits.seven_day.used_percentage // 0 | floor)%(\\($s7 / 86400 | floor)d\\($s7 % 86400 / 3600 | floor)h) | cost: $\\((.cost.total_cost_usd // 0) * 10000 | floor / 10000)\"'"
  },
  "language": "japanese",
  "effortLevel": "high"
}
